{
  "$schema": "https://raw.githubusercontent.com/govuk-one-login/quality-gates/refs/tags/v0.1.0/schemas/schema.json",
  "services": [
    {
      "service-tag": "mobile-ios-one-login-app",
      "quality-gates": [
        {
          "check-types": [
            "code style and linting",
            "unit test coverage",
            "code quality",
            "secret scanning",
            "vulnerability detection"
          ],
          "config": {
            "file": ".github/workflows/pull-request.yml",
            "name": "Build and Test code base when pull request is published/updated",
            "path": "jobs.build"
          },
          "phase": "pre-merge",
          "provider": "GitHub"
        },
        {
          "check-types": [
            "unit test coverage",
            "code quality",
            "secret scanning"
          ],
          "config": {
            "file": ".github/workflows/quality-report.yml",
            "name": "Run Quality Report (on merge)",
            "path": "jobs.build"
          },
          "phase": "pre-upload",
          "provider": "GitHub"
        }
      ]
    }
  ]
}
